# RoCo AI — Web App (Next.js 15)
#
# Builds the Next.js visualizer and serves it on port 3000.
# Talks to the gateway (GATEWAY_URL) for trace data.

FROM node:24-slim AS builder

WORKDIR /app

# Copy monorepo root manifests for pnpm workspace resolution
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

# Copy the web app package
COPY apps/web/package.json apps/web/.npmrc apps/web/

# Install all workspace dependencies (uses root lockfile)
RUN corepack enable && pnpm install --frozen-lockfile

# Copy the web app source and build
COPY apps/web/ apps/web/
RUN pnpm --filter @roco/web build

FROM node:24-slim

WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
ENV GATEWAY_URL=http://gateway:3001

COPY --from=builder /app/apps/web/.next apps/web/.next
COPY --from=builder /app/apps/web/package.json apps/web/
COPY --from=builder /app/apps/web/next.config.ts apps/web/
COPY --from=builder /app/apps/web/public apps/web/public

EXPOSE 3000

CMD ["pnpm", "--filter", "@roco/web", "start"]
