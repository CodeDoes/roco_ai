+//! REAL framework — no stubs. Mock backend included.
+use std::collections::HashMap;
+pub trait DomainHarness {
+    fn name(&self) -> &'static str;
+    fn init(&mut self, cfg: HarnessConfig);
+    fn run(&self, input: &str, ctx: &Context) -> Result<String, HarnessError>;
+    fn verify(&self, output: &str) -> bool;
+    fn rollback(&self, state: &State) -> State;
+}
+#[derive(Clone, Debug)]
+pub struct HarnessConfig { pub model_path: String, pub workspace_dir: String, pub max_retries: u32, pub strict_grammar: bool }
+#[derive(Clone, Debug, Default)]
+pub struct Context { pub session_id: String, pub memory: Vec<String>, pub tool_results: HashMap<String, String> }
+#[derive(Clone, Debug, Default)]
+pub struct State { pub checkpoint: String, pub attempts: u32 }
+#[derive(Debug)]
+pub enum HarnessError { MockNotReady, VerificationFailed, RollbackError }
+impl std::fmt::Display for HarnessError { ... }
+pub struct MockBackend;
+impl MockBackend { pub fn generate(&self, prompt: &str) -> String { format!("MOCK_INFERENCE_RESULT: {}", prompt.trim()) } }
+